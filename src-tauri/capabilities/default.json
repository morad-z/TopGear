{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://wa.me/*" },
        { "url": "https://web.whatsapp.com/*" },
        { "url": "https://api.whatsapp.com/*" }
      ]
    }
  ]
}
