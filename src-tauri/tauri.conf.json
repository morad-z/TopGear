{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TopGear",
  "version": "0.1.6",
  "identifier": "com.topgear.garage",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TopGear - ניהול מוסך",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "ניהול מוסך אופליין",
    "longDescription": "TopGear — מערכת לניהול עבודות, מלאי חלקים ומסירות, שעובדת מקומית במחשב.",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwNkREMzJENzlDRjlCNDMKUldSRG04OTVMZE50MFBLWVdaN1QvYnppZGt5cVVkaitBM3FpN1N4R0t5UFBKVm5vbXROSmdRdHEK",
      "endpoints": [
        "https://github.com/morad-z/TopGear/releases/latest/download/latest.json"
      ]
    }
  }
}
